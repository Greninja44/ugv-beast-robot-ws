# robot_dashboard settings (overrides defaults in core/config.py; env DASH_* wins over this).
# Copy this file to dashboard.yaml and fill in your own values — dashboard.yaml is
# gitignored so your control token never ends up in version control.
port: 8080

# SECURITY: leave auth_token unset for read-only mode. Set a long random string to
# enable control operations (teleop, nav, controls) from clients that present it.
# Generate one with: python3 -c "import secrets; print(secrets.token_urlsafe(24))"
# Enter this exact value in the dashboard's Manual Control page to unlock driving.
# auth_token: "change-me-long-random-string"

cors_origins:
  - "http://localhost:5173"

# Channel rates (Hz) pushed to browsers; server-enforced.
rate_telemetry: 2.0
rate_odom: 10.0
rate_imu: 10.0
rate_scan: 5.0

# Teleop ceilings (Phase 2). Vendor: slow=0.2, max=1.3 m/s.
max_linear: 0.5
max_angular: 1.2
